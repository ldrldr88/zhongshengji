{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "framework": null,
  "trailingSlash": true,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(html|css|js|json)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/about",      "destination": "/about/", "permanent": true },
    { "source": "/yuyue",      "destination": "/yuyue/", "permanent": true },
    { "source": "/zhong-sheng-ji-shi-shen-me",     "destination": "/zhong-sheng-ji-shi-shen-me/",     "permanent": true },
    { "source": "/zhong-sheng-ji-jia-ge-fei-yong", "destination": "/zhong-sheng-ji-jia-ge-fei-yong/", "permanent": true },
    { "source": "/zhong-sheng-ji-duojiu-jian-xiao","destination": "/zhong-sheng-ji-duojiu-jian-xiao/","permanent": true },
    { "source": "/zhong-sheng-ji-pian-ju-bian-bie","destination": "/zhong-sheng-ji-pian-ju-bian-bie/","permanent": true },
    { "source": "/taiwan-lin-laoshi-zhong-sheng-ji","destination": "/taiwan-lin-laoshi-zhong-sheng-ji/","permanent": true }
  ]
}
